{
  "name": "pi-tincan",
  "version": "2.0.0",
  "description": "Barebone ask_user_question extension package for pi coding agent.",
  "type": "module",
  "private": true,
  "keywords": [
    "pi-package",
    "pi-extension"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "pack:dry": "npm pack --dry-run"
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts",
      "./extensions/tincan-squad/index.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.75.1",
    "@earendil-works/pi-coding-agent": ">=0.75.1",
    "@earendil-works/pi-tui": ">=0.75.1",
    "typebox": ">=1.1.24"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typebox": "^1.1.38",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
